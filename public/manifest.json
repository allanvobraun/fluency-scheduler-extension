{
  "manifest_version": 3,
  "name": "Fluency Extension",
  "version": "1.0.0",
  "description": "Simple browser extension using Vite and TypeScript",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://academy.fluency.io/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": []
}
