{
  "name": "fluency",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test tests/e2e/sandbox.spec.ts",
    "test:smoke": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test  tests/e2e/real-site.spec.ts --debug",
    "auth:save": "node tests/e2e/save-auth.js",
    "check": "npm run build && npm run lint && npm run test && npm run test:e2e",
    "zip": "npm run build && cd dist && zip -r ../fluency-extension.zip ."
  },
  "dependencies": {
    "@open-wc/testing": "^4.0.0",
    "lit": "^3.3.2",
    "luxon": "^3.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/chrome": "^0.1.36",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "dotenv": "^16.6.1",
    "eslint": "^9.38.0",
    "jsdom": "^27.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
